<% layout("/layouts/boilerplate") %>

    <!-- The above line means the content written in body of layouts/boilerplate.ejs will be display on currnet eje file -->


    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h3><b>
                    <%= listing.title %>
                </b></h3>
        </div>

        <div class="card col-6 offset-2 show-card listing-card">
            <img class="card-img-top show-img"
                src="<%= listing.image || 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c' %>"
                alt="Listing image">
            <div class="card-body">
                <p class="card-text">
                    <br>
                    <b>Owned By : </b><i>
                        <%= listing.owner.username %>
                    </i><br>


                <p class="card-text">
                    <%= listing.description %>
                </p>
                <p class="card-text">&#8377; <%= listing.price.toLocaleString('en-IN') %>
                </p>
                <p class="card-text">
                    <%= listing.location %>
                </p>
                <p class="card-text">
                    <%= listing.country %>
                </p>

            </div>
        </div>

        <% if(currUser && listing.owner._id.equals(currUser._id)) {%>
            <div class="btns col-8 offset-2 mt-3 d-flex gap-2">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn">EDIT</a>

                <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
                    <button class="btn btn-dark">DELETE</button>
                </form>
            </div>
            <% } %>


                <div class="col-8 offset-2">
                    <% if(currUser) {%>
                        <hr>
                        <h4>Leave a Review</h4>
                        <!-- note - novalidate (in form )means = skip browser’s automatic validation, let developer handle it. -->
                        <form class="mb-3 needs-validation" action="/listings/<%=listing.id%>/reviews" method="post"
                            novalidate>

                            <div class="mb-3 mt-3">
                                <label class="form-label" for="rating">Rating</label>
                                <input class="form-range" type="range" name="review[rating]" id="rating" min="1"
                                    max="5">
                            </div>
                            <div class="mb-3 mt-3">

                                <label class="form-label" for="comment">Comments</label>
                                <br>
                                <textarea required class="form-control" name="review[comment]" id="comment" cols="30"
                                    rows="5"></textarea>
                                <div class="invalid-feedback">
                                    Please add some comments for review.
                                </div>

                            </div>
                            <button class="btn btn-outline-dark">Submit</button>
                        </form>
                        <% } %>
                            <hr>
                            <p><b>All Reviews</b></p>
                            <div class="row">

                                <%for(r of listing.reviews){%>
                                    <div class="card col-5 ms-3 mb-3">
                                        <div class="card-body">
                                            <h5 class="card-title">
                                                @<%= 
                                                    r.author.username%>
                                            </h5>
                                            <p class="card-text">
                                                <%= r.comment%>
                                            </p>
                                            <p class="card-text">
                                                <%= r.rating%> &#9733;
                                            </p>

                                        </div>
                                        <!-- ?_method=DELETE is method over riding -->
                                        <form class="mb-3" method="POST"
                                            action="/listings/<%= listing._id %>/reviews/<%= r._id%>?_method=DELETE">
                                            <button class="btn btn-sm btn-dark">Delete</button>
                                        </form>

                                    </div>
                                    <%}%>
                            </div>
                </div>
    </div>